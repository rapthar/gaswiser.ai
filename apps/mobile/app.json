{
  "expo": {
    "name": "Gas Wiser",
    "slug": "gaswiser",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "gaswiser",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0060A9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gaswiser.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Gas Wiser needs your location to find nearby gas stations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0060A9"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "package": "com.gaswiser.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        { "locationWhenInUsePermission": "Gas Wiser needs your location to find nearby gas stations." }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
